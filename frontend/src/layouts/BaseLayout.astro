---
import "../styles/global.css"

interface Props {
	title?: string
}

const { title = "RunWise" } = Astro.props
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="RunWise helps runners discover the best shoes through intelligent scraping and ranking."
		/>
		<title>{title}</title>
	</head>
	<body>
		<div class="bg-orb orb-one" aria-hidden="true"></div>
		<div class="bg-orb orb-two" aria-hidden="true"></div>
		<main>
			<slot />
		</main>
	</body>
</html>
